// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "session": {
    "trust_all_worktrees": true,
  },
  "proxy": "",
  "diff_view_style": "split",
  "ui_font_size": 15.0,
  "show_edit_predictions": true,
  "outline_panel": {
    "button": false,
    "dock": "right",
  },
  "collaboration_panel": {
    "button": false,
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "edit_predictions": {
    "provider": "zed",
  },
  "agent_ui_font_size": 15.0,
  "ui_font_family": ".ZedSans",
  "icon_theme": "Catppuccin Latte",
  "debugger": {
    "button": false,
  },
  "buffer_line_height": {
    "custom": 2.5,
  },
  "inline_code_actions": true,
  "gutter": {
    "min_line_number_digits": 3,
    "folds": false,
    "breakpoints": false,
    "runnables": false,
  },
  "agent_servers": {
    "Cursor local": {
      "default_config_options": {
        "mode": "agent",
      },
      "type": "custom",
      "command": "agent",
      "args": ["--trust", "--yolo", "acp"],
    },
    "cursor": {
      "default_config_options": {
        "model": "grok-4.5",
      },
      "type": "registry",
    },
  },
  "scrollbar": {
    "show": "system",
    "cursors": false,
    "axes": {
      "horizontal": true,
    },
  },
  "rounded_selection": true,
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_branch_status_icon": false,
    "show_menus": false,
    "show_sign_in": false,
    "show_user_picture": false,
    "show_onboarding_banner": false,
    "show_project_items": true,
    "show_branch_name": true,
  },
  "search": {
    "button": false,
  },
  "diagnostics": {
    "button": true,
  },
  "terminal": {
    "button": false,
  },
  "status_bar": {
    "active_language_button": false,
  },
  "toolbar": {
    "agent_review": true,
    "selections_menu": true,
    "quick_actions": false,
    "breadcrumbs": false,
  },
  "base_keymap": "VSCode",
  "sticky_scroll": {
    "enabled": false,
  },
  "minimap": {
    "show": "never",
  },
  "cursor_blink": false,
  "max_tabs": 5,
  "buffer_font_fallbacks": ["Menlo", "Monaco", "Courier New"],
  "buffer_font_family": "JetBrains Mono",
  "file_types": {
    "html": ["*.blade.php"],
    "php": ["*.module"],
  },
  "colorize_brackets": false,
  "wrap_guides": [80],
  "agent": {
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "terminal": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "read_file": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "write_file": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "edit_file": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "list_directory": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "create_directory": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "delete_path": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "move_path": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "copy_path": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "grep": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "find_path": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "diagnostics": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "fetch": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "skill": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "spawn_agent": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "dirname": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
        "web_search_0": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*"}]
        },
      },
    },
    "enable_feedback": false,
    "dock": "left",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "tab_bar": {
    "show_tab_bar_buttons": false,
    "show": true,
    "show_nav_history_buttons": false,
  },
  "buffer_font_size": 12.5,
  "vim_mode": true,
  "theme": {
    "mode": "system",
    "light": "Flexoki Light",
    "dark": "Flexoki Dark",
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "languages": {
    "PHP": {
      "language_servers": [
        "phpantom",
        "!intelephense",
        "!phpactor",
        "!phptools",
      ],
      "format_on_save": "off",
    },
    "Markdown": {
      "preferred_line_length": 90,
      "soft_wrap": "prefer_line",
    },
    "Nix": {
      "language_servers": ["nixd", "!nil"]
    }
  },
  "project_panel": {
    "git_status": true,
    "dock": "right",
    "button": false,
    "indent_size": 15,
  },
  "relative_line_numbers": "enabled",
}
