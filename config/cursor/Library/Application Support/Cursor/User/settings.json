{
    "telemetry.telemetryLevel": "off",


    // --------------------------- ESP-IDF related ---------------------------
    "files.exclude": {
        "**/__pycache__": true,
        "!**/database.sqlite": false,
        "!storage/logs/laravel.log": false,
    },

    "search.quickOpen.includeHistory": false,

    "security.workspace.trust.untrustedFiles": "open",
    "security.workspace.trust.enabled": false,

    // ------------------------------ Workbench --------------------------------
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.value": 5,
    "workbench.editor.tabSizing": "shrink",
    "workbench.preferredLightColorTheme": "Flexoki Light Red",
    "workbench.startupEditor": "none",


    "workbench.editorAssociations": {
        "*.svg": "default"
    },

    "window.autoDetectColorScheme": true,

    // ------------------------------ Explorer --------------------------------
    "explorer.openEditors.visible": 1,
    "explorer.openEditors.minVisible": 1,
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },
    "explorer.autoRevealExclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/vendor": true
    },

    // ------------------------------ Vim mode ------------------------------
    // Enable relative line numbers
    "vim.smartRelativeLine": true,
    "vim.foldfix": true,


    // ------------------------------ PHP ------------------------------------
    "intelephense.files.associations": [
        "*.php",
        "*.phtml"
    ],
    "php.suggest.basic": false,

    // ------------------------------ TypeScript ------------------------------
    "typescript.updateImportsOnFileMove.enabled": "always",

    "files.associations": {
        "*.blade.php": "html",
        "*.module": "php"
    },


    "workbench.activityBar.location": "hidden",
    "workbench.colorCustomizations": {
        "[Quiet Light]": {
            "statusBar.background": "#EDEDF5",
            "statusBar.foreground": "#705697"
        },
    },

    "window.density.editorTabHeight": "default",
    "extensions.ignoreRecommendations": true,

    "scm.diffDecorations": "gutter",
    "diffEditor.codeLens": true,

    "editor.fontFamily": "JetBrainsMono Nerd Font Mono, Menlo, Monaco, 'Courier New', monospace",
    "editor.peekWidgetDefaultFocus": "editor",
    "editor.guides.highlightActiveIndentation": "always",
    "editor.cursorBlinking": "solid",
    "editor.minimap.enabled": false,
    "editor.rulers": [
        {
            "column": 80,
            "color": "#eae9e9"
        }
    ],
    "editor.bracketPairColorization.enabled": false,
    "editor.lineHeight": 2.5,
    "editor.fontLigatures": true,
    "editor.scrollbar.verticalScrollbarSize": 6,
    "editor.scrollbar.horizontalScrollbarSize": 4,

    "[markdown]": {
        "editor.wordWrap": "wordWrapColumn"
    },

    "terminal.integrated.tabs.location": "left",
    "terminal.integrated.tabs.enabled": false,
    "terminal.integrated.enablePersistentSessions": false,
    "editor.stickyScroll.enabled": false,
    "intelephense.phpdoc.returnVoid": false,
    "git.blame.editorDecoration.enabled": false,
    "editor.glyphMargin": false,
    "[php]": {
        "editor.defaultFormatter": "laravel.vscode-laravel"
    },
    "git.blame.statusBarItem.enabled": false,
    "window.titleBarStyle": "native",
    "custom-ui-style.webview.enable": false,
    "custom-ui-style.webview.removeCSP": false,
    "custom-ui-style.extensions.enable": false,
    "custom-ui-style.electron": {
        "frame": false,
    },
    "editor.inlayHints.enabled": "off",
    "editor.gotoLocation.multipleDefinitions": "goto",
    "editor.gotoLocation.multipleDeclarations": "goto",
    "editor.gotoLocation.multipleImplementations": "gotoAndPeek",
    "workbench.sideBar.location": "right",
    "githubPullRequests.codingAgent.enabled": false,
    "githubPullRequests.experimental.chat": false,
    "githubPullRequests.codingAgent.uiIntegration": false,
    "githubIssues.assignWhenWorking": false,
    "githubPullRequests.codingAgent.autoCommitAndPush": false,
    "githubPullRequests.codingAgent.promptForConfirmation": false,
    "window.commandCenter": false,
    "Laravel.artisanMake.commandPalette": false,
    "workbench.settings.enableNaturalLanguageSearch": false,
    "files.watcherExclude": {
        "**/build/**": true,
        "**/dist/**": true,
        "**/node_modules/**": true,
        "**/public/build/**": true,
        "**/vendor/**": true
    },
    "workbench.layoutControl.enabled": false,
    "zenMode.fullScreen": false,
    "zenMode.centerLayout": false,
    "zenMode.hideStatusBar": false,
    "glspc.serverCommand": "/Users/xavier/Downloads/phpantom_lsp",
    "glspc.languageId": "php",
    "workbench.iconTheme": "catppuccin-latte",
    "breadcrumbs.symbolPath": "last",
    "git.openRepositoryInParentFolders": "always",
    "cursor.general.fontSmoothingAntialiased": true,
    "idf.hasWalkthroughBeenShown": true,
    "idf.showOnboardingOnInit": false,
    "idf.gitPath": "/opt/homebrew/bin/git",
    "idf.eimIdfJsonPath": "/Users/xavier/.espressif/tools/eim_idf.json",
    "idf.eimExecutableArgs": [
        "wizard",
        "--idf-features ide"
    ],
    "idf.customExtraVars": {
        "IDF_PATH": "${env:HOME}/esp/esp-idf-v4.4.8",
        "IDF_TOOLS_PATH": "${env:HOME}/.espressif",
        "IDF_PYTHON_ENV_PATH": "${env:HOME}/.espressif/python_env/idf4.4_py3.11_env",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
        "PATH": "${env:HOME}/.espressif/tools/xtensa-esp-elf-gdb/11.2_20220823/xtensa-esp-elf-gdb/bin:${env:HOME}/.espressif/tools/riscv32-esp-elf-gdb/11.2_20220823/riscv32-esp-elf-gdb/bin:${env:HOME}/.espressif/tools/xtensa-esp32-elf/esp-2021r2-patch5-8.4.0/xtensa-esp32-elf/bin:${env:HOME}/.espressif/tools/xtensa-esp32s2-elf/esp-2021r2-patch5-8.4.0/xtensa-esp32s2-elf/bin:${env:HOME}/.espressif/tools/xtensa-esp32s3-elf/esp-2021r2-patch5-8.4.0/xtensa-esp32s3-elf/bin:${env:HOME}/.espressif/tools/riscv32-esp-elf/esp-2021r2-patch5-8.4.0/riscv32-esp-elf/bin:${env:HOME}/.espressif/tools/esp32ulp-elf/2.35_20220830/esp32ulp-elf/bin:${env:HOME}/.espressif/tools/openocd-esp32/v0.12.0-esp32-20240318/openocd-esp32/bin:${env:HOME}/.espressif/python_env/idf4.4_py3.11_env/bin:${env:HOME}/esp/esp-idf-v4.4.8/tools:/opt/homebrew/bin"
    },
    "idf.enableCCache": true,
    "terraform.languageServer.rootModules": [
        "terraform"
    ],
    "cursor.composer.editorConversationDensity": "detailed",
    "breadcrumbs.enabled": false,
}
